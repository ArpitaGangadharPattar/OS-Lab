#include <stdio.h>
#include <stdlib.h>

int main()
{
    int n,i,AT[100],BT[100],CT[100],WT[100],TAT[100],Pid[100];
    float avgTAT,avgWT,sumTAT=0,sumWT=0;
    printf("Enter the number of processes:");
    scanf("%d",&n);
    for(i=0;i<n;i++)
    {
        printf("\nEnter the Arrival time of process %d:",i+1);
        scanf("%d",&AT[i]);
        printf("\nEnter the Burst time of process %d:",i+1);
        scanf("%d",&BT[i]);
        Pid[i]=i+1;


    }
    int min=AT[0];
    for (i=0;i<n;i++)
    {
        if(AT[i]<min)
        {
           AT[i]=min;
        }
    }
    int current_time=0;
    for(i=0;i<n;i++)
    {
        if(current_time<AT[i])
            current_time=AT[i];
        CT[i]=current_time+BT[i];
        TAT[i]=CT[i]-AT[i];
        WT[i]=TAT[i]-BT[i];
        current_time=CT[i];
        sumTAT+=TAT[i];
        sumWT+=WT[i];

    }
    avgTAT=sumTAT/n;
    avgWT=sumWT/n;
    for(i=0;i<n;i++)
    {
        printf("\nProcess ID:%d",Pid[i]);
        printf("\nArrival time:%d",AT[i]);
        printf("\nBurst time:%d",BT[i]);
        printf("\nWaiting time:%d",WT[i]);
        printf("\nTurnaround time:%d\n",TAT[i]);
        
    }
    printf("\nAverage Turnaround time is %f",avgTAT);
    printf("\nAverage Waiting tiume is %f",avgWT);
}
